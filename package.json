{
  "name": "vuepress-plugin-knowledge-graph",
  "version": "0.1.0",
  "description": "A VuePress 2 plugin that generates an Obsidian-like knowledge graph from Markdown links, tags, and categories.",
  "type": "module",
  "license": "MIT",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src"
  ],
  "keywords": [
    "vuepress",
    "vuepress-plugin",
    "knowledge-graph",
    "obsidian",
    "markdown"
  ],
  "peerDependencies": {
    "vue": "^3.5.0",
    "vuepress": "^2.0.0-rc.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.0.0"
  }
}
